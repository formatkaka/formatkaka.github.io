---
import Layout from '../../layouts/Layout.astro';
import { GalileoStars as GalileoStarsSection } from '../../components/react/galileo-stars';
---

<Layout
  title="Galileo + Stars"
  description="A dark editorial-inspired concept page for Galileo AI with a telescope motif and animated starfield."
>
  <div class="page">
    <div class="container">
      <GalileoStarsSection
        client:only="react"
        companyName="Galileo AI"
        headline="Design with clarity, launch with confidence."
        description="Galileo AI helps product teams transform intent into polished interface directions faster. This concept highlights the company through a telescope-inspired visual and a living starfield to represent discovery, precision, and forward momentum."
        websiteLabel="Visit Galileo AI"
        websiteHref="https://www.galileo.ai"
        imageSrc="/assets/galileo-telescope.png"
      />
    </div>
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    padding: 2rem 1rem 4rem;
    background: radial-gradient(circle at 20% 0%, #10173a 0%, #050713 45%, #02030a 100%);
  }

  .container {
    margin: 0 auto;
    max-width: 1100px;
  }

  @keyframes twinkle {
    0%,
    100% {
      opacity: 0.2;
      transform: scale(0.85);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }
</style>
